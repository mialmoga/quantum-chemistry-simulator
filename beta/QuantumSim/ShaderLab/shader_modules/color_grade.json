{
  "id": "color_grade",
  "name": "Color Grade",
  "stage": "frag",
  "target": [
    "orbital",
    "sphere"
  ],
  "color": "#fb923c",
  "desc": "Tinte RGB independiente por canal + correcci\u00f3n gamma",
  "sub": "col = pow(col \u00b7 tint, 1/gamma)",
  "params": {
    "r": {
      "label": "Tinte R",
      "min": 0.5,
      "max": 2.0,
      "step": 0.02,
      "val": 1.0
    },
    "g": {
      "label": "Tinte G",
      "min": 0.5,
      "max": 2.0,
      "step": 0.02,
      "val": 1.0
    },
    "b": {
      "label": "Tinte B",
      "min": 0.5,
      "max": 2.0,
      "step": 0.02,
      "val": 1.0
    },
    "gamma": {
      "label": "Gamma",
      "min": 0.5,
      "max": 2.5,
      "step": 0.05,
      "val": 1.0
    }
  },
  "glsl": "col=pow(max(col*vec3({{r}},{{g}},{{b}}),vec3(0.0)),vec3(1.0/{{gamma}}));",
  "requires": [
    "brightness"
  ],
  "provides": []
}