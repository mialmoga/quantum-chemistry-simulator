{
  "id": "sphere_pulse",
  "name": "Sphere Pulse",
  "stage": "vert",
  "target": [
    "sphere"
  ],
  "color": "#f472b6",
  "desc": "Pulso en tama\u00f1o de punto \u2014 modula gl_PointSize sin romper point_size",
  "sub": "r += sin(t\u00b7freq) \u00b7 amp",
  "params": {
    "freq": {
      "label": "Frecuencia",
      "min": 0.5,
      "max": 20.0,
      "step": 0.5,
      "val": 12.0
    },
    "amp": {
      "label": "Amplitud",
      "min": 0.0,
      "max": 0.5,
      "step": 0.01,
      "val": 0.15
    },
    "pSize": {
      "label": "Pt size",
      "min": 0.1,
      "max": 3.0,
      "step": 0.05,
      "val": 1.0
    }
  },
  "glsl": "{float _v=sin(uTime*{{freq}}+vPhase*6.2832)*{{amp}};float _base=gl_PointSize>0.0?gl_PointSize:{{pSize}}*uScale*uAspect*350.0/-mvP.z;gl_PointSize=_base*(1.0+_v);}",
  "requires": [],
  "provides": [
    "gl_PointSize"
  ]
}