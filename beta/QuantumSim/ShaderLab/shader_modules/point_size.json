{
  "id": "point_size",
  "name": "Point Size",
  "stage": "vert",
  "target": [
    "orbital",
    "sphere"
  ],
  "color": "#00e5ff",
  "desc": "Tama\u00f1o de part\u00edcula con perspectiva y blink",
  "sub": "scale \u00b7 size \u00b7 (1 + blink\u00b7amp) / z",
  "params": {
    "sz": {
      "label": "Tama\u00f1o",
      "min": 0.1,
      "max": 3.0,
      "step": 0.05,
      "val": 0.1
    },
    "bAmp": {
      "label": "Amp blink",
      "min": 0.0,
      "max": 6.0,
      "step": 0.1,
      "val": 0.0
    },
    "persp": {
      "label": "Perspectiva",
      "min": 0,
      "max": 400,
      "step": 1,
      "val": 10.0
    }
  },
  "glsl": "gl_PointSize=uScale*{{sz}}*(1.1+vBlink*{{bAmp}})*{{persp}}*uAspect/-mvP.z;",
  "requires": [],
  "provides": [
    "gl_PointSize"
  ]
}