<path class="st5 svg-elem-41" d="M150.5,130.1c1.8,1,3.7,1.9,5.5,2.9c0.5,0.3,1.9,1,2.3,1.4c-1.1,1-1.8,2.4-2.1,3.8c-2.6-1.5-5.3-2.8-7.9-4.3C149.4,132.8,150.1,131.5,150.5,130.1z"/>
<path class="st5 svg-elem-42" d="M48.7,130.1c0.5,1.4,1.2,2.7,2.1,3.8c-2.7,1.4-5.3,3-8,4.4c-0.3-1.4-1-2.7-2-3.8C43,133.2,46.4,131.4,48.7,130.1z"/>
            </svg>
        </div>
        <div class="loading-modal__title">Quantum Chemistry Simulator</div>
        <div class="loading-modal__status" id="loadingStatus">Iniciando...</div>
        <div class="loading-modal__bar-wrap">
            <div class="loading-modal__bar" id="loadingBar"></div>
        </div>
        <div class="loading-modal__detail" id="loadingDetail"></div>

        <!-- Panel de configuración — aparece tras la carga completa -->
        <div class="loading-modal__config" id="loadingConfig">
            <div class="config-divider"></div>

            <!-- Idioma -->
            <div class="config-section">
                <span class="config-label" data-i18n="session.language_label">Idioma / Language</span>
                <div class="config-pills" role="radiogroup" aria-label="Idioma">
                    <button class="config-pill active" data-lang="es" aria-pressed="true">ES</button>
                    <button class="config-pill" data-lang="en" aria-pressed="false">EN</button>
                </div>
            </div>

            <!-- Calidad visual -->
            <div class="config-section">
                <span class="config-label" data-i18n="settings.graphics_quality">Calidad visual</span>
                <div class="config-quality" role="radiogroup" aria-label="Calidad visual">
                    <label class="quality-option" data-res="standard">
                        <input type="radio" name="quality" value="standard" hidden>
                        <div class="quality-dot"></div>
                        <div class="quality-text">
                            <span class="quality-name" data-i18n="settings.quality_low">Básica</span>
                            <span class="quality-desc" data-i18n="session.q_standard_desc">5 k pts · rápido</span>
                        </div>
                    </label>
                    <label class="quality-option active" data-res="high">
                        <input type="radio" name="quality" value="high" checked hidden>
                        <div class="quality-dot"></div>
                        <div class="quality-text">
                            <span class="quality-name" data-i18n="settings.quality_high">Alta</span>
                            <span class="quality-desc" data-i18n="session.q_high_desc">10 k pts · recomendado</span>
                        </div>
                    </label>
                    <label class="quality-option" data-res="ultra">
                        <input type="radio" name="quality" value="ultra" hidden>
                        <div class="quality-dot"></div>
                        <div class="quality-text">
                            <span class="quality-name" data-i18n="session.q_ultra">Cuántica™</span>
                            <span class="quality-desc" data-i18n="session.q_ultra_desc">20 k pts · exigente</span>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Botón de inicio -->
            <button class="config-launch" id="launchBtn" aria-label="Iniciar simulador">
                <span class="config-launch__text" data-i18n="session.continue">Iniciar</span>
                <svg class="config-launch__arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
        </div>
    </div>
</div>

<script>
    setTimeout(() => {
        const svg = document.querySelector('#loading-modal .wrapper svg');
        if (svg) svg.classList.add('active');
    }, 100);
</script>

<!-- UI: fade approach + settings dropdown -->
<script>
(function() {
    const header       = document.getElementById('app-header');
    const dock         = document.getElementById('dock');
    const restoreBtn   = document.getElementById('ui-restore-btn');
    const settingsBtn  = document.getElementById('settingsBtn');
    const settingsDrop = document.getElementById('settingsDropdown');
    const visorSliderWrap = document.getElementById('visorSliderWrap');
    const visorBtn     = document.getElementById('visorBtn');

    let faded = false;
    let idleTimer = null;
    const IDLE_MS = 5000;

    function fadeUI() {
        // Don't fade if a panel is open
        const anyPanelOpen = document.querySelector('.side-panel:not(.hidden)') ||
                             document.querySelector('.bottom-sheet:not(.hidden)') ||
                             document.querySelector('.dev-console:not(.hidden)');
        if (anyPanelOpen) { resetIdleTimer(); return; }
        if (settingsDrop.classList.contains('open')) { resetIdleTimer(); return; }

        faded = true;
        header.classList.add('ui-faded');
        dock.classList.add('ui-faded');
        restoreBtn.classList.add('visible');
    }

    function restoreUI() {
        faded = false;
        header.classList.remove('ui-faded');
        dock.classList.remove('ui-faded');
        restoreBtn.classList.remove('visible');
        resetIdleTimer();
    }

    function resetIdleTimer() {
        clearTimeout(idleTimer);
        idleTimer = setTimeout(fadeUI, IDLE_MS);
    }

    // ⚪ restore button
    restoreBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        restoreUI();
    });

    // Stats buttons (atom/molecule mode) still work when faded
    // Dock center button (▲) still works when faded
    // These are kept pointer-events:auto via CSS

    // Settings dropdown toggle
    settingsBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        settingsDrop.classList.remove('hidden');
        const open = settingsDrop.classList.contains('open');
        if (open) {
            settingsDrop.classList.remove('open');
        } else {
            settingsDrop.classList.add('open');
            restoreUI(); // ensure UI is visible when settings open
        }
    });

    // Close dropdown on outside click
    document.addEventListener('click', (e) => {
        if (!e.target.closest('.settings-wrap')) {
            settingsDrop.classList.remove('open');
        }
    });

    // Visor slider visibility
    visorBtn?.addEventListener('click', () => {
        setTimeout(() => {
            const active = visorBtn.classList.contains('active');
            visorSliderWrap.classList.toggle('visible', active);
        }, 50);
    });

    // Start idle timer after load
    window.addEventListener('load', () => {
        setTimeout(resetIdleTimer, 2000);
    });
})();
</script>

<script type="module" src="app.js"></script>
</body>
</html>
