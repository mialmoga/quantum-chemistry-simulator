<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Quantum Chemistry Simulator</title>

    <!-- PWA & Icons -->
    <link rel="manifest" href="site.webmanifest">
    <link rel="icon" type="image/svg+xml" href="ShaderLab/assets/icons/favicon.svg">
    <link rel="icon" type="image/x-icon"  href="ShaderLab/assets/icons/favicon.ico">
    <link rel="apple-touch-icon" href="ShaderLab/assets/icons/apple-touch-icon.png">
    <!-- Import Map — Three.js local (r182) -->
    <script type="importmap">
    {
      "imports": {
        "three":          "/lib/three/build/three.module.js",
        "three/addons/":  "/lib/three/examples/jsm/",
        "three/webgpu":   "/lib/three/build/three.webgpu.js",
        "three/tsl":      "/lib/three/build/three.tsl.js"
      }
    }
    </script>

    <!-- Styles — rutas originales del proyecto -->
    <link rel="stylesheet" href="css/base.css">
    <link rel="stylesheet" href="css/loader.css">
    <link rel="stylesheet" href="css/variables.css">
    <link rel="stylesheet" href="css/panels.css">
</head>
<body data-mode="design">

<!-- ═══════════════════════════════════════════════════════
     HEADER — siempre visible
═══════════════════════════════════════════════════════ -->
<header id="app-header">
    <div class="header__left">
        <button id="forceReloadBtn" class="header__logo" title="Forzar recarga">
            <svg width="22" height="22" viewBox="0 0 204.6 204.6" fill="none">
                <circle cx="102.3" cy="102.3" r="18" fill="currentColor" opacity=".9"/>
                <ellipse cx="102.3" cy="102.3" rx="90" ry="34" stroke="currentColor" stroke-width="6" fill="none" opacity=".6"/>
                <ellipse cx="102.3" cy="102.3" rx="90" ry="34" stroke="currentColor" stroke-width="6" fill="none" opacity=".6" transform="rotate(60 102.3 102.3)"/>
                <ellipse cx="102.3" cy="102.3" rx="90" ry="34" stroke="currentColor" stroke-width="6" fill="none" opacity=".6" transform="rotate(120 102.3 102.3)"/>
            </svg>
        </button>
        <span class="header__title"><span class="title-full">Quantum Chemistry Simulator</span><span class="title-short">QSim</span></span>
    </div>

    <div class="header__center">
        <div class="mode-toggle" id="modeToggle">
            <button class="mode-toggle__btn mode-toggle__btn--active" id="modeDesign" data-mode="design">
                <span class="mode-toggle__icon">✏️</span>
                <span class="mode-toggle__label">Diseño</span>
            </button>
            <div class="mode-toggle__divider"></div>
            <button class="mode-toggle__btn" id="modeSim" data-mode="sim">
                <span class="mode-toggle__icon">▶</span>
                <span class="mode-toggle__label">Sim</span>
            </button>
        </div>
    </div>

    <div class="header__right">
        <div class="header__stats">
            <span class="hstat hstat--mode hstat--active" id="modeAtom" title="Modo: seleccionar átomos">⚛ <b id="atomCount">0</b></span>
            <span class="hstat hstat--mode" id="modeMolecule" title="Modo: seleccionar moléculas">⬡ <b id="moleculeCount">0</b></span>
            <span class="hstat" title="Enlaces">— <b id="bondCount">0</b></span>
        </div>
        <!-- ⚙️ Settings toggle -->
        <div class="settings-wrap" id="settingsWrap">
            <button class="header__fs-btn" id="settingsBtn" title="Configuración">⚙️</button>
            <div class="settings-dropdown hidden" id="settingsDropdown">
                <button class="settings-opt" id="rawModeBtn" title="Modo Raw — shader sin bloom">
                    <span class="settings-opt__icon">💎</span><span>Raw Mode</span>
                </button>
                <button class="settings-opt" id="soundBtn" title="Sonido atómico">
                    <span class="settings-opt__icon">🎧</span><span>Audio</span>
                </button>
                <button class="settings-opt" id="visorBtn" title="Filtro óptico — atenuar brillo">
                    <span class="settings-opt__icon">🕶</span><span>Visor</span>
                </button>
                <div class="settings-slider" id="visorSliderWrap">
                    <input type="range" id="visorSlider" min="0.05" max="1.0" step="0.05" value="0.25">
                    <span id="visorValue">25%</span>
                </div>
                <button class="settings-opt" id="gestureBtn" title="Control gestual — webcam">
                    <span class="settings-opt__icon">✋</span><span>Gestos</span>
                </button>
                <button class="settings-opt" id="lodBtn" title="LOD Orbitales — renderizar orbitales en escena (desactivar = solo esfera)">
                    <span class="settings-opt__icon">🔬</span><span>LOD Orbitales</span>
                </button>
            </div>
        </div>
        <button class="header__fs-btn" id="fullscreenBtn" title="Pantalla completa">⛶</button>
    </div>
</header>

<!-- Visor slider ahora dentro del panel ⚙️ -->

<!-- ⚪ Restore button — siempre visible, restaura paneles completos -->
<button id="ui-restore-btn" title="Mostrar paneles">⚪</button>

<!-- ═══════════════════════════════════════════════════════
     CANVAS AREA
═══════════════════════════════════════════════════════ -->
<div id="canvas-wrap">
    <div class="canvas-hint" id="canvasHint">
        Tap para agregar · Arrastra para rotar · Pinch para zoom
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════
     PANEL IZQUIERDO — Física / Geometría / Lab / Temperatura
═══════════════════════════════════════════════════════ -->
<aside id="panel-left" class="side-panel side-panel--left hidden">
    <nav class="side-panel__tabs">
        <button class="sptab sptab--active" data-tab="physics">⚛️ Física</button>
        <button class="sptab" data-tab="geometry">📐 Geo</button>
        <button class="sptab" data-tab="lab">🧪 Lab</button>
        <button class="sptab" data-tab="temperature">🌡️ Temp</button>
    </nav>

    <div class="side-panel__body">

        <!-- ── TAB FÍSICA ── -->
        <div class="tab-content" id="tab-physics">
            <div class="panel-section">
                <label class="check-row"><input type="checkbox" id="gravityToggle"><span>🌍 Gravedad</span></label>
                <p class="hint">A escala atómica la gravedad es imperceptible — usa el multiplicador del Lab para exagerarla</p>
                <div class="slider-wrap">
                    <input type="range" id="gravitySlider" min="0" max="10" value="5" step="0.5">
                    <span class="slider-val" id="gravityValue">x5</span>
                </div>
            </div>
            <div class="panel-section">
                <label class="check-row"><input type="checkbox" id="repulsionToggle" checked><span>⚛️ Repulsión Atómica</span></label>
                <p class="hint">Evita colapso de estructuras</p>
            </div>
            <div class="panel-section">
                <label class="check-row"><input type="checkbox" id="cpkColorToggle"><span>🎨 Colores CPK</span></label>
                <p class="hint">Estándar internacional de colores</p>
            </div>
            <div class="panel-section">
                <label class="check-row"><input type="checkbox" id="bondsToggle" checked><span>🔗 Mostrar Enlaces</span></label>
                <p class="hint">Oculta cilindros y electrones de enlace</p>
            </div>
            <div class="panel-section">
                <label class="check-row"><input type="checkbox" id="bondAnglesToggle" checked><span>📐 Ángulos de Enlace</span></label>
                <p class="hint">Geometría molecular realista (H₂O bent, CH₄ tetrahedral)</p>
            </div>
            <div class="panel-section">
                <label class="check-row"><input type="checkbox" id="lennardJonesToggle"><span>🌊 Fuerzas Van der Waals</span></label>
                <p class="hint">Lennard-Jones potential</p>
            </div>
            <div class="panel-section panel-section--accent">
                <div class="section-title">⚛️ Modo de Física</div>
                <label class="check-row"><input type="checkbox" id="strictBondingToggle"><span><b>⚗️ Afinidad Estricta</b></span></label>
                <p class="hint">H, F, Cl, Br, I respetan su valencia máxima</p>
                <label class="check-row" class="mt-sm"><input type="checkbox" id="physicsModeToggle" checked><span>🔬 Modo Realista</span></label>
                <p class="hint"><b>OFF:</b> Pedagógico (enlaces discretos)<br><b>ON:</b> Realista (campos continuos)</p>
            </div>
            <div class="panel-section">
                <label class="check-row"><input type="checkbox" id="toggleVisualization"><span>☁️ Nubes electrónicas</span></label>
                <label class="check-row" class="mt-xs"><input type="checkbox" id="toggleElectrons" checked><span>⚛️ Mostrar todos los e⁻</span></label>
            </div>
        </div>

        <!-- ── TAB GEOMETRÍA ── -->
        <div class="tab-content tab-content--hidden" id="tab-geometry">
            <div class="section-title">🏠 Techo</div>
            <div class="panel-section">
                <div class="row-with-btn">
                    <label class="check-row"><input type="checkbox" id="ceilingToggle"><span>Techo (física)</span></label>
                    <button id="ceilingVisibilityBtn" class="btn-sm">👁 Visible</button>
                </div>
                <div class="slider-row"><span>Opacidad</span><input type="range" id="ceilingOpacitySlider" min="0" max="0.6" value="0.15" step="0.05"><span class="slider-val" id="ceilingOpacityValue">0.15</span></div>
                <div class="slider-row"><span>Brillo</span><input type="range" id="ceilingBrightnessSlider" min="0" max="1" value="0.1" step="0.1"><span class="slider-val" id="ceilingBrightnessValue">0.1</span></div>
                <div class="slider-row"><span>Rebote</span><input type="range" id="ceilingBounceSlider" min="0" max="1" value="0.6" step="0.1"><span class="slider-val" id="ceilingBounceValue">0.6</span></div>
                <div class="slider-row"><span>Altura</span><input type="range" id="ceilingYSlider" min="5" max="40" step="1" value="15"><span class="slider-val" id="ceilingYValue">15</span></div>
                <div class="slider-row"><span>Curvatura</span><input type="range" id="ceilingCurvatureSlider" min="-0.5" max="0.5" step="0.01" value="0"><span class="slider-val" id="ceilingCurvatureValue">0.00</span></div>
                <p class="hint">← cóncavo | plano | convexo (cúpula) →</p>
            </div>

            <div class="section-title" class="mt-lg">🌍 Piso</div>
            <div class="panel-section">
                <div class="row-with-btn">
                    <label class="check-row"><input type="checkbox" id="floorToggle" checked><span>Piso (física)</span></label>
                    <button id="floorVisibilityBtn" class="btn-sm">👁 Visible</button>
                </div>
                <div class="slider-row"><span>Opacidad</span><input type="range" id="floorOpacitySlider" min="0" max="1" value="0.15" step="0.05"><span class="slider-val" id="floorOpacityValue">0.15</span></div>
                <div class="slider-row"><span>Brillo</span><input type="range" id="floorBrightnessSlider" min="0" max="1" value="0.1" step="0.1"><span class="slider-val" id="floorBrightnessValue">0.1</span></div>
                <div class="slider-row"><span>Rebote</span><input type="range" id="bounceSlider" min="0" max="1" value="0.6" step="0.1"><span class="slider-val" id="bounceValue">0.6</span></div>
                <div class="slider-row"><span>Curvatura</span><input type="range" id="floorCurvatureSlider" min="-0.5" max="0.5" step="0.01" value="0"><span class="slider-val" id="floorCurvatureValue">0.0</span></div>
                <p class="hint">← cóncavo (bowl) | plano | convexo (dome) →</p>
            </div>

            <div class="section-title" class="mt-lg">🔮 Esfera recipiente</div>
            <div class="panel-section">
                <div class="row-with-btn">
                    <label class="check-row"><input type="checkbox" id="sphereToggle"><span>Esfera (física)</span></label>
                    <button id="sphereVisibilityBtn" class="btn-sm">👁 Visible</button>
                </div>
                <div class="slider-row"><span>Opacidad</span><input type="range" id="sphereOpacitySlider" min="0" max="0.5" value="0.08" step="0.02"><span class="slider-val" id="sphereOpacityValue">0.08</span></div>
                <div class="slider-row"><span>Rebote</span><input type="range" id="sphereBounceSlider" min="0" max="1" value="0.6" step="0.1"><span class="slider-val" id="sphereBounceValue">0.6</span></div>
                <div class="slider-row"><span>Centro Y</span><input type="range" id="sphereCenterYSlider" min="-15" max="15" value="0" step="1"><span class="slider-val" id="sphereCenterYValue">0</span></div>
                <div class="slider-row"><span>Radio</span><input type="range" id="sphereRadiusSlider" min="5" max="50" step="1" value="20"><span class="slider-val" id="sphereRadiusValue">20</span></div>
                <div class="section-title" class="mt-sm text-xs">🌡️ Polos térmicos</div>
                <div class="slider-row"><span>🔴 Polo Sur</span><input type="range" id="sphereBottomTempSlider" min="0" max="2000" step="10" value="0"><span class="slider-val" id="sphereBottomTempValue">0 K</span></div>
                <div class="slider-row"><span>🔵 Polo Norte</span><input type="range" id="sphereTopTempSlider" min="0" max="2000" step="10" value="0"><span class="slider-val" id="sphereTopTempValue">0 K</span></div>
                <p class="hint">Gradiente vertical: calor abajo ↔ frío arriba</p>
            </div>
        </div>

        <!-- ── TAB LABORATORIO ── -->
        <div class="tab-content tab-content--hidden" id="tab-lab">
            <p class="lab-warning">⚠️ Valores por defecto = física real<br>Experimenta bajo tu propio riesgo</p>
            <div class="slider-row"><span>🌍 Gravedad</span><input type="range" id="gravityLabSlider" min="0" max="1e-10" step="1e-12" value="0"><span class="slider-val" id="gravityLabValue">0</span></div>
            <div class="slider-row"><span>⚛️ Pauli Strength</span><input type="range" id="pauliStrengthSlider" min="0" max="1000" step="10" value="500"><span class="slider-val" id="pauliStrengthValue">500</span></div>
            <div class="slider-row"><span>⚛️ Pauli Factor</span><input type="range" id="pauliFactorSlider" min="1.0" max="3.0" step="0.1" value="2.0"><span class="slider-val" id="pauliFactorValue">2.0</span></div>
            <div class="slider-row"><span>💨 Fricción</span><input type="range" id="frictionSlider" min="0.80" max="1.0" step="0.01" value="0.98"><span class="slider-val" id="frictionValue">0.98</span></div>
            <div class="slider-row"><span>🚀 Vel. Terminal</span><input type="range" id="terminalVelSlider" min="0.5" max="10" step="0.5" value="2.0"><span class="slider-val" id="terminalVelValue">2.0</span></div>
            <div class="slider-row"><span>🔗 Spring Enlace</span><input type="range" id="bondSpringSlider" min="0.1" max="3.0" step="0.1" value="1.0"><span class="slider-val" id="bondSpringValue">1.0</span></div>
            <div class="slider-row"><span>📐 Fuerza Ángulos</span><input type="range" id="bondAnglesSlider" min="0" max="1.0" step="0.05" value="0.5"><span class="slider-val" id="bondAnglesValue">0.5</span></div>
            <div class="slider-row"><span>🌊 Lennard-Jones</span><input type="range" id="lennardJonesSlider" min="0" max="1.0" step="0.05" value="0.1"><span class="slider-val" id="lennardJonesValue">0.1</span></div>
            <div class="slider-row"><span>🌡️ Rango Irrad.</span><input type="range" id="surfaceRadRangeSlider" min="1" max="20" step="0.5" value="6.0"><span class="slider-val" id="surfaceRadRangeValue">6.0</span></div>
            <div class="slider-row"><span>🔥 Int. Irrad.</span><input type="range" id="surfaceRadStrengthSlider" min="0" max="1" step="0.05" value="0.4"><span class="slider-val" id="surfaceRadStrengthValue">0.4</span></div>
            <div class="btn-row" class="mt-lg">
                <button id="resetPhysicsDefaults" class="btn btn--blue">🔄 Reset</button>
                <button id="randomizePhysics" class="btn btn--gold">🎲 Random</button>
            </div>
        </div>

        <!-- ── TAB TEMPERATURA ── -->
        <div class="tab-content tab-content--hidden" id="tab-temperature">
            <div class="mode-row">
                <span class="label-xs">Modo:</span>
                <div class="seg-ctrl">
                    <button class="seg-btn seg-btn--active" id="tempModeDidactic">🎓 Didáctico</button>
                    <button class="seg-btn" id="tempModeRealistic">⚗️ Realista</button>
                </div>
            </div>
            <p class="hint" id="tempModeDesc">Escala pedagógica — valores inventados para visibilidad.</p>
            <div class="panel-section">
                <label class="check-row"><input type="checkbox" id="tempEnabledToggle"><span>Activar sistema de temperatura</span></label>
            </div>
            <div class="section-title" class="mt-md">🌍 Temperatura Ambiental</div>
            <div class="slider-row"><span>🌡️ Objetivo</span><input type="range" id="tempSlider" min="0" max="2000" step="10" value="300"><span class="slider-val" id="tempTargetValue">300 K</span></div>
            <div class="readout-box">
                <div class="readout-row"><span>T actual:</span><span id="tempCurrentValue" class="readout-val">— K</span></div>
                <div class="readout-row"><span>Fase:</span><span id="tempPhaseValue" class="readout-phase">—</span></div>
            </div>
            <div class="panel-section">
                <label class="check-row"><input type="checkbox" id="tempColorToggle" checked><span>🎨 Color de ambiente por temperatura</span></label>
                <p class="hint">azul = frío · naranja = caliente · ámbar = plasma</p>
            </div>
            <div class="panel-section">
                <label class="check-row"><input type="checkbox" id="tempBondBreakToggle"><span>🔥 Ruptura de enlaces por calor</span></label>
                <label class="check-row"><input type="checkbox" id="thermalDissociationToggle"><span>⚛️ Disociación Térmica (Boltzmann)</span></label>
                <label class="check-row"><input type="checkbox" id="metathesisToggle"><span>⚗️ Metátesis (A-B + C-D → A-C + B-D)</span></label>
            </div>
            <div class="slider-row"><span>⏱️ Vel. termostato</span><input type="range" id="tempTauSlider" min="5" max="200" step="5" value="60"><span class="slider-val" id="tempTauValue">60</span></div>
            <p class="hint">Bajo = brusco · Alto = gradual y suave</p>
            <div class="section-title" class="mt-md">🔥 Temperatura del Suelo</div>
            <div class="slider-row"><span>T suelo</span><input type="range" id="floorTempSlider" min="0" max="3000" step="50" value="0"><span class="slider-val" id="floorTempValue">0 K</span></div>
            <p class="hint">Calienta átomos por contacto y proximidad</p>
            <div class="section-title" class="mt-md">❄️ Temperatura del Techo</div>
            <div class="slider-row"><span>T techo</span><input type="range" id="ceilingTempSlider" min="0" max="3000" step="50" value="0"><span class="slider-val" id="ceilingTempValue">0 K</span></div>
            <p class="hint">Enfría o calienta átomos por proximidad</p>
        </div>

    </div><!-- /side-panel__body -->
</aside>

<!-- ═══════════════════════════════════════════════════════
     PANEL DERECHO — Quantum View (átomo seleccionado)
═══════════════════════════════════════════════════════ -->
<aside id="panel-right" class="side-panel side-panel--right hidden">
    <div class="qv-header">
        <div class="qv-atom-id">
            <span class="qv-symbol" id="qvSymbol">—</span>
            <div class="qv-meta">
                <span class="qv-name" id="qvName">Sin selección</span>
                <span class="qv-config" id="qvConfig"></span>
            </div>
        </div>
        <button class="btn-close-panel" id="closeQV">✕</button>
    </div>
    <div class="qv-canvas-wrap" id="qvCanvasWrap">
        <div class="qv-canvas-placeholder"><span>Selecciona un átomo<br>para ver sus orbitales</span></div>
    </div>
    <div class="side-panel__body">
        <div class="qv-layers">
            <div class="section-title">Capas</div>
            <label class="check-row" style="padding:4px 0;font-size:12px">
                <input type="checkbox" id="qvSphereToggle">
                <span>◉ Esfera LOD</span>
            </label>
            <div id="qvLayerList" class="qv-layer-list"></div>
        </div>
        <div class="qv-material" class="mt-md">
            <div class="section-title">Material</div>
            <div class="slider-row"><span>Brillo</span><input type="range" id="qvBrightness" min="0" max="2" step="0.05" value="1"><span class="slider-val" id="qvBrightnessVal">1.0</span></div>
            <div class="slider-row"><span>Tamaño pt</span><input type="range" id="qvPtSize" min="0.5" max="4" step="0.1" value="1.5"><span class="slider-val" id="qvPtSizeVal">1.5</span></div>
            <div class="btn-row" class="mt-sm">
                <button id="qvOpenMaterials" class="btn btn--blue" class="flex-1">🎨 Materiales</button>
                <button id="qvLoadProfile"   class="btn btn--panel" class="flex-1">📂 Cargar</button>
                <button id="qvSaveProfile"   class="btn btn--gold"  class="flex-1">💾 Guardar</button>
            </div>
            <input type="file" id="qvProfileInput" accept=".json" hidden>
        </div>
    </div>
</aside>

<!-- ═══════════════════════════════════════════════════════
     PANEL GRUPOS (lateral derecho, flotante)
═══════════════════════════════════════════════════════ -->
<div id="groupPanel" class="group-panel hidden"></div>

<!-- ═══════════════════════════════════════════════════════
     BOTTOM SHEETS
═══════════════════════════════════════════════════════ -->

<!-- Selector de Elementos (bottom-center) -->
<div class="bottom-sheet hidden" id="elementSelector">
    <input class="element-search" id="elementSearch" type="search" placeholder="Buscar…" autocomplete="off">
    <div class="element-grid" id="elementGrid"></div>
</div>

<!-- Panel Agregar (bottom-right) -->
<div class="bottom-sheet bottom-sheet--right hidden" id="addPanel">
    <h4 class="bs-title">➕ Agregar</h4>
    <div class="seg-ctrl seg-ctrl--3" class="mb-md">
        <button class="seg-btn seg-btn--active" id="showMolecules">⚗️ Moléculas</button>
        <button class="seg-btn" id="showCrystals">💎 Cristales</button>
        <button class="seg-btn" id="showSnowflake">❄️ Copo</button>
    </div>
    <div id="moleculesSection"><div id="moleculeButtons" class="add-grid"></div></div>
    <div id="crystalsSection" class="hidden">
        <div class="add-grid-2">
            <button class="btn btn--panel" id="crystalNaCl">🧂 NaCl</button>
            <button class="btn btn--panel" id="crystalFe">🔩 Hierro</button>
            <button class="btn btn--panel" id="crystalDiamond">💎 Diamante</button>
            <button class="btn btn--panel" id="crystalIce">❄️ Hielo</button>
        </div>
        <div class="slider-row" class="mt-sm">
            <span>Tamaño</span>
            <input type="range" id="crystalSizeSlider" min="2" max="6" value="3" step="1">
            <span class="slider-val"><span id="crystalSizeValue">3</span>×<span id="crystalSizeValue2">3</span>×<span id="crystalSizeValue3">3</span></span>
        </div>
        <label class="check-row" class="mt-xs"><input type="checkbox" id="freezeCrystalToggle"><span>Congelar estructura</span></label>
    </div>
    <div id="snowflakeSection" class="hidden">
        <div class="slider-row"><span>Complejidad</span><input type="range" id="sfComplexitySlider" min="1" max="5" value="2" step="1"><span class="slider-val" id="sfComplexityValue">2</span></div>
        <div class="slider-row"><span>Humedad</span><input type="range" id="sfHumiditySlider" min="0" max="1" value="0.7" step="0.05"><span class="slider-val" id="sfHumidityValue">0.7</span></div>
        <div class="slider-row"><span>Variedad ADN</span><input type="range" id="sfChaosSlider" min="0" max="1" value="0.4" step="0.05"><span class="slider-val" id="sfChaosValue">0.4</span></div>
        <div class="btn-row" class="mt-sm">
            <button class="btn btn--blue" id="sfGenerate" class="flex-1">❄️ Generar</button>
            <button class="btn btn--gold" id="sfSave" class="flex-1">💾 Guardar</button>
        </div>
        <button class="btn btn--panel" id="sfSilverBlue" class="btn--silverblue mt-xs">✨ Azul Plata</button>
        <div class="btn-row" class="mt-xs">
            <button class="btn btn--panel" id="sfLoad" class="flex-1">📂 Cargar</button>
        </div>
        <input type="file" id="sfFileInput" accept=".json" class="u-hidden">
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════
     CONSOLA DEL MOTOR (panel flotante)
═══════════════════════════════════════════════════════ -->
<div id="devConsole" class="dev-console hidden">
    <div class="dev-console__header">
        <span class="dev-console__title">⌨️ Consola</span>
        <div class="dev-console__actions">
            <button id="consoleClear" class="btn-sm" title="Limpiar">🗑</button>
            <button id="consoleClose" class="btn-close-panel">✕</button>
        </div>
    </div>
    <div class="dev-console__log" id="consoleLog"></div>
    <div class="dev-console__input-row">
        <span class="dev-console__prompt">❯</span>
        <input type="search" id="consoleInput" class="dev-console__input"
               placeholder="QSim.world.addAtom('Fe') · Tab para completar"
               autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
               enterkeyhint="go">
        <button id="consoleRun" class="btn btn--blue btn--compact">Run</button>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════
     DOCK — botones de panel
═══════════════════════════════════════════════════════ -->
<div id="dock">
    <button class="dock-btn" id="dockPhysics">
        <span class="dock-icon">⚛️</span>
        <span class="dock-label">Física</span>
    </button>
    <button class="dock-btn" id="dockShaderLab" onclick="location.href='ShaderLab/index.html'">
        <span class="dock-icon">🎨</span>
        <span class="dock-label">ShaderLab</span>
    </button>
    <button class="dock-btn dock-btn--center" id="dockElements">
        <span class="dock-icon">▲</span>
    </button>
    <button class="dock-btn" id="dockQuantumView" onclick="location.href='QuantumView.html'">
        <span class="dock-icon">🔬</span>
        <span class="dock-label">Quantum</span>
    </button>
    <button class="dock-btn" id="dockAdd">
        <span class="dock-icon">➕</span>
        <span class="dock-label">Agregar</span>
    </button>
</div>

<!-- Grupos lateral + Consola -->
<button class="collapse-side collapse-side--groups" id="collapseGroups">◀ Grupos</button>
<button class="collapse-side collapse-side--console" id="collapseConsole">⌨️</button>

<!-- ═══════════════════════════════════════════════════════
     TEMPERATURE HUD
═══════════════════════════════════════════════════════ -->
<div id="temp-hud" class="temp-hud hidden">
    <div class="temp-hud__row"><span class="temp-hud__label">🌡️ Ambiente</span><span class="temp-hud__value" id="hudAmbientTemp">— K</span><span class="temp-hud__phase" id="hudPhase">—</span></div>
    <div class="temp-hud__divider"></div>
    <div class="temp-hud__row"><span class="temp-hud__label">🔥 Suelo</span><span class="temp-hud__value" id="hudFloorTemp">— K</span></div>
    <div class="temp-hud__row"><span class="temp-hud__label">❄️ Techo</span><span class="temp-hud__value" id="hudCeilingTemp">— K</span></div>
</div>

<!-- ═══════════════════════════════════════════════════════
     HINT NOTIFICATION
═══════════════════════════════════════════════════════ -->
<div id="hint"></div>

