/**
 * QuantumRenderer.js
 *
 * The representation layer. The only place where Three.js objects live.
 *
 * This renderer reads simulation snapshots and decides how to show them.
 * It NEVER touches a QuantumEntity or Hadron directly.
 * It NEVER writes back to the simulation.
 *
 * That separation is the whole point.
 *
 * Visual philosophy for this renderer:
 *   - A quark is shown as a soft, glowing field volume — not a sphere.
 *     Because a quark is a condition of space, not a ball.
 *   - Color charge → actual RGB color (didactic: R=red, G=green, B=blue)
 *   - Tension drives glow intensity: high tension = bright, unstable.
 *     Low tension (confined) = dim, settled.
 *   - Hadrons get a faint bounding glow to make them readable,
 *     but the quarks inside are still visible — the hadron is recognition,
 *     not a container.
 *
 * Units: 1 world unit = 1 pm. Scene scale matches simulation scale exactly.
 * Compatible with Three.js r183.
 *
 * Future: swap this entire file for a different renderer
 * (wireframe, isosurface, abstract) without touching one line of physics.
 */

import * as THREE from 'three';
import { COLOR } from './QuantumEntity.js';

// ─── Color charge → visual color mapping ─────────────────────────────────────
// Didactic choice: use actual RGB. Not physically meaningful, pedagogically clear.
const COLOR_VISUAL = {
    [COLOR.R]:      new THREE.Color(0xff3a3a),  // red
    [COLOR.G]:      new THREE.Color(0x3aff6e),  // green
    [COLOR.B]:      new THREE.Color(0x3a8fff),  // blue
    [COLOR.ANTI_R]: new THREE.Color(0x00cccc),  // cyan (anti-red)
    [COLOR.ANTI_G]: new THREE.Color(0xcc00cc),  // magenta (anti-green)
    [COLOR.ANTI_B]: new THREE.Color(0xcccc00),  // yellow (anti-blue)
};

// ─── Hadron identity → accent color ──────────────────────────────────────────
const HADRON_ACCENT = {
    proton:   new THREE.Color(0x88aaff),
    neutron:  new THREE.Color(0xaaaaaa),
    'delta++': new THREE.Color(0xffaa00),
    'delta-':  new THREE.Color(0xff4488),
    exotic:    new THREE.Color(0xff00ff),
};

// ─── Quark visual radius in wu (pm) ──────────────────────────────────────────
// Displayed larger than "real" (quarks have no known size) for readability.
const QUARK_DISPLAY_RADIUS = 0.12;
const HADRON_DISPLAY_RADIUS = 0.45;


export class QuantumRenderer {

    /**
     * @param {THREE.Scene}  scene     The Three.js scene to render into
     * @param {Object}       opts
     * @param {boolean}      opts.showHadronBounds   Show hadron boundary glow
     * @param {boolean}      opts.showTensionGlow     Show tension as glow intensity
     * @param {boolean}      opts.showFreeQuarks      Show unconfined quarks
     */
    constructor(scene, opts = {}) {
        this.scene = scene;

        this.opts = {
            showHadronBounds:  opts.showHadronBounds  ?? true,
            showTensionGlow:   opts.showTensionGlow   ?? true,
            showFreeQuarks:    opts.showFreeQuarks     ?? true,
        };

        // Object pools: Maps from entity/hadron id → Three.js object
        this._quarkMeshes  = new Map();
        this._hadronMeshes = new Map();

        // Shared geometries (one per type — never duplicate geometry)
        this._quarkGeo  = new THREE.SphereGeometry(QUARK_DISPLAY_RADIUS, 12, 8);
        this._hadronGeo = new THREE.SphereGeometry(HADRON_DISPLAY_RADIUS, 16, 10);

        // Shared base material (cloned per quark for individual color)
        this._baseMaterial = new THREE.MeshStandardMaterial({
            roughness:    0.0,
            metalness:    0.0,
            transparent:  true,
            opacity:      0.85,
        });

        this._hadronMaterial = new THREE.MeshStandardMaterial({
            roughness:   1.0,
            metalness:   0.0,
            transparent: true,
            opacity:     0.08,
            side:        THREE.FrontSide,
            depthWrite:  false,
        });

        // Ambient + directional light — added once, owned by renderer
        this._setupLights();
    }

    _setupLights() {
        const ambient = new THREE.AmbientLight(0xffffff, 0.4);
        ambient.name = 'qr_ambient';
        this.scene.add(ambient);

        const dir = new THREE.DirectionalLight(0xffffff, 0.8);
        dir.position.set(5, 10, 7);
        dir.name = 'qr_directional';
        this.scene.add(dir);
    }

    // ─── Main update ──────────────────────────────────────────────────────────

    /**
     * Update the visual representation from a simulation snapshot.
     * Call this every frame after simulation.step().
     *
     * @param {Object} snapshot   Output of Simulation._snapshot()
     */
    update(snapshot) {
        this._updateQuarks(snapshot.entities, snapshot.hadrons);
        this._updateHadrons(snapshot.hadrons);
        this._garbageCollect(snapshot);
    }

    // ─── Quark rendering ──────────────────────────────────────────────────────

    _updateQuarks(entities, hadrons) {
        // Build a quick lookup: which entity ids are in a hadron?
        const confinedIds = new Set();
        for (const h of hadrons) {
            for (const q of h.quarks) confinedIds.add(q.id);
        }

        for (const entity of entities) {
            // Skip free quarks if option disabled
            const isFree = !confinedIds.has(entity.id);
            if (isFree && !this.opts.showFreeQuarks) {
                this._hideQuark(entity.id);
                continue;
            }

            let mesh = this._quarkMeshes.get(entity.id);

            // Create mesh if it doesn't exist yet
            if (!mesh) {
                mesh = this._createQuarkMesh(entity);
                this._quarkMeshes.set(entity.id, mesh);
                this.scene.add(mesh);
            }

            // Update position
            mesh.position.copy(entity.position);

            // Update color based on color charge
            const baseColor = COLOR_VISUAL[entity.color]
                ?? new THREE.Color(0xffffff);

            // Tension drives emissive intensity:
            // High tension (free quark) → bright glow
            // Low tension (confined) → settled, dim
            const emissiveIntensity = this.opts.showTensionGlow
                ? entity.tension * 1.5
                : 0.2;

            mesh.material.color.copy(baseColor);
            mesh.material.emissive.copy(baseColor);
            mesh.material.emissiveIntensity = emissiveIntensity;

            // Confined quarks are slightly more transparent
            mesh.material.opacity = isFree ? 0.92 : 0.80;

            mesh.visible = true;
        }
    }

    _createQuarkMesh(entity) {
        const mat = this._baseMaterial.clone();
        const mesh = new THREE.Mesh(this._quarkGeo, mat);
        mesh.name = `quark_${entity.id}`;
        return mesh;
    }

    _hideQuark(id) {
        const mesh = this._quarkMeshes.get(id);
        if (mesh) mesh.visible = false;
    }

    // ─── Hadron boundary rendering ────────────────────────────────────────────

    _updateHadrons(hadrons) {
        if (!this.opts.showHadronBounds) return;

        for (const hadron of hadrons) {
            let mesh = this._hadronMeshes.get(hadron.id);

            if (!mesh) {
                mesh = this._createHadronMesh(hadron);
                this._hadronMeshes.set(hadron.id, mesh);
                this.scene.add(mesh);
            }

            // Position at center of mass
            mesh.position.copy(hadron.position);

            // Accent color by identity
            const accent = HADRON_ACCENT[hadron.identity]
                ?? HADRON_ACCENT.exotic;

            mesh.material.color.copy(accent);
            mesh.material.emissive.copy(accent);

            // Fade in as hadron stabilizes
            const stabilityOpacity = hadron.stable
                ? 0.08
                : 0.08 * (hadron.age / hadron.settleTime);

            mesh.material.emissiveIntensity = hadron.stable ? 0.3 : 0.1;
            mesh.material.opacity = stabilityOpacity;

            mesh.visible = true;
        }
    }

    _createHadronMesh(hadron) {
        const mat = this._hadronMaterial.clone();
        const mesh = new THREE.Mesh(this._hadronGeo, mat);
        mesh.name = `hadron_${hadron.id}`;
        return mesh;
    }

    // ─── Garbage collection ───────────────────────────────────────────────────

    /**
     * Remove meshes for entities/hadrons that no longer exist.
     */
    _garbageCollect(snapshot) {
        const liveEntityIds = new Set(snapshot.entities.map(e => e.id));
        const liveHadronIds = new Set(snapshot.hadrons.map(h => h.id));

        for (const [id, mesh] of this._quarkMeshes) {
            if (!liveEntityIds.has(id)) {
                this.scene.remove(mesh);
                mesh.material.dispose();
                this._quarkMeshes.delete(id);
            }
        }

        for (const [id, mesh] of this._hadronMeshes) {
            if (!liveHadronIds.has(id)) {
                this.scene.remove(mesh);
                mesh.material.dispose();
                this._hadronMeshes.delete(id);
            }
        }
    }

    // ─── Cleanup ──────────────────────────────────────────────────────────────

    /**
     * Dispose all Three.js resources. Call when tearing down.
     */
    dispose() {
        for (const mesh of this._quarkMeshes.values()) {
            this.scene.remove(mesh);
            mesh.material.dispose();
        }
        for (const mesh of this._hadronMeshes.values()) {
            this.scene.remove(mesh);
            mesh.material.dispose();
        }

        this._quarkGeo.dispose();
        this._hadronGeo.dispose();
        this._baseMaterial.dispose();
        this._hadronMaterial.dispose();

        this._quarkMeshes.clear();
        this._hadronMeshes.clear();
    }
}
