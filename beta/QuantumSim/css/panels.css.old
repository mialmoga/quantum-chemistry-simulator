/* ═══════════════════════════════════════════════════════════
   QUANTUM CHEMISTRY SIMULATOR — panels.css
   Proyecto nuevo — diseño limpio desde cero
   ═══════════════════════════════════════════════════════════ */

/* ── Tokens ─────────────────────────────────────────────── */
:root {
    /* Accent cambia con el modo */
    --accent:       #4fc3f7;
    --accent-dim:   rgba(79, 195, 247, 0.18);
    --accent-glow:  rgba(79, 195, 247, 0.35);

    --sim-accent:     #69f0ae;
    --sim-accent-dim: rgba(105, 240, 174, 0.18);

    --bg-panel:     rgba(8, 10, 18, 0.88);
    --bg-panel-alt: rgba(12, 16, 26, 0.92);
    --border:       rgba(255, 255, 255, 0.07);
    --text:         #d8e4f0;
    --text-dim:     rgba(216, 228, 240, 0.45);
    --text-xs:      rgba(216, 228, 240, 0.35);

    --gold:   #ffd54f;
    --red:    #ef5350;

    --panel-w:     272px;
    --header-h:    50px;
    --dock-h:      52px;
    --radius:      14px;
    --radius-sm:   8px;

    /* Fonts — definidas en css/base.css del proyecto */
    --font-mono: var(--font-code, 'Space Mono', monospace);
    --font-ui:   var(--font-body, system-ui, sans-serif);

    /* Temperatura ambiental (actualizado por JS) */
    --ambient-temp-rgb: 5, 7, 14;
}

[data-mode="sim"] {
    --accent:      var(--sim-accent);
    --accent-dim:  var(--sim-accent-dim);
    --accent-glow: rgba(105, 240, 174, 0.35);
}

/* ── Reset mínimo ────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
    width: 100%; height: 100%;
    overflow: hidden;
    background: transparent;
    color: var(--text);
    font-family: var(--font-ui);
    font-size: 13px;
    -webkit-font-smoothing: antialiased;
}

body {
    background: transparent;
}

button { font-family: inherit; cursor: pointer; }

/* ═══════════════════════════════════════════════════════════
   HEADER
   ═══════════════════════════════════════════════════════════ */
#app-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--header-h);
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 14px;
    background: none;
    border-bottom: none;
    gap: 10px;
    isolation: isolate; /* creates new stacking context */
}
/* Background layer — separate so we can fade it independently */
#app-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(6, 8, 16, 0.45);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    z-index: -1; /* behind content but INSIDE the isolated context */
    transition: opacity 0.5s ease;
}
/* Fade state — bg layer disappears, non-essential buttons fade */
#app-header.ui-faded::before {
    opacity: 0;
}
/* Fade: solo el fondo desaparece, fullscreen se oculta (⚪ lo reemplaza) */
#app-header.ui-faded #fullscreenBtn {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
}
/* Todos los demás elementos del header siguen visibles */
#app-header .header__left,
#app-header .header__center,
#app-header .header__stats,
#app-header .header__right,
#app-header .settings-wrap {
    transition: opacity 0.4s ease;
}

.header__left {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
    flex: 1;
}

.header__logo {
    color: var(--accent);
    background: none;
    border: none;
    padding: 4px;
    border-radius: 6px;
    opacity: 0.85;
    transition: opacity 0.2s, transform 0.2s;
    flex-shrink: 0;
}
.header__logo:hover { opacity: 1; transform: rotate(30deg); }

.header__title {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.7);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    letter-spacing: 0.01em;
}
/* Portrait: mostrar versión corta */
.header__title .title-short { display: none; }
.header__title .title-full  { display: inline; }

@media (max-width: 600px) {
    .header__title .title-full  { display: none; }
    .header__title .title-short { display: inline; }
}

.header__center { flex-shrink: 0; }

.header__right {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
}

.header__stats {
    display: flex;
    gap: 10px;
}

.hstat {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
}
.hstat b { color: var(--text); font-weight: 700; }

.header__fs-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-dim);
    border-radius: var(--radius-sm);
    width: 30px; height: 30px;
    font-size: 15px;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.2s;
}
.header__fs-btn:hover { border-color: var(--accent); color: var(--accent); }

/* ── Mode toggle ─────────────────────────────────────────── */
.mode-toggle {
    display: flex;
    align-items: center;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 3px;
    gap: 2px;
}

.mode-toggle__btn {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 4px 12px;
    border-radius: 16px;
    border: none;
    background: transparent;
    color: var(--text-dim);
    font-size: 12px;
    font-weight: 500;
    transition: all 0.22s ease;
}

.mode-toggle__btn--active {
    background: var(--accent-dim);
    color: var(--accent);
    font-weight: 600;
}

.mode-toggle__icon { font-size: 11px; }
.mode-toggle__divider { width: 1px; height: 16px; background: var(--border); }

/* ═══════════════════════════════════════════════════════════
   CANVAS
   ═══════════════════════════════════════════════════════════ */
#canvas-wrap {
    position: fixed;
    inset: 0;
    z-index: 0;
}

.canvas-hint {
    position: absolute;
    top: calc(var(--header-h) + 10px);
    left: 50%;
    transform: translateX(-50%);
    font-size: 10px;
    color: var(--text-xs);
    pointer-events: none;
    white-space: nowrap;
    letter-spacing: 0.04em;
    text-transform: uppercase;
}

/* ═══════════════════════════════════════════════════════════
   SIDE PANELS
   ═══════════════════════════════════════════════════════════ */
.side-panel {
    position: fixed;
    top: var(--header-h);
    bottom: var(--dock-h);
    width: var(--panel-w);
    background: var(--bg-panel);
    backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    z-index: 150;
    transition: transform 0.28s cubic-bezier(0.4,0,0.2,1),
                opacity 0.28s ease;
    overflow: hidden;
}

.side-panel--left  { left: 0;  border-left: none; border-radius: 0 var(--radius) var(--radius) 0; }
.side-panel--right { right: 0; border-right: none; border-radius: var(--radius) 0 0 var(--radius); }

.side-panel.hidden {
    opacity: 0;
    pointer-events: none;
}
.side-panel--left.hidden  { transform: translateX(-100%); }
.side-panel--right.hidden { transform: translateX(100%); }

/* Tab bar */
.side-panel__tabs {
    display: flex;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    padding: 6px 8px 0;
    gap: 2px;
}

.sptab {
    flex: 1;
    padding: 7px 4px;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    color: var(--text-dim);
    font-size: 11px;
    font-weight: 500;
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    transition: all 0.18s;
    white-space: nowrap;
}

.sptab--active {
    color: var(--accent);
    border-bottom-color: var(--accent);
    background: var(--accent-dim);
}

.sptab:hover:not(.sptab--active) {
    color: var(--text);
    background: rgba(255,255,255,0.04);
}

/* Scrollable body */
.side-panel__body {
    flex: 1;
    overflow-y: auto;
    padding: 14px 14px 20px;
}

.side-panel__body::-webkit-scrollbar { width: 3px; }
.side-panel__body::-webkit-scrollbar-track { background: transparent; }
.side-panel__body::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 2px; }

/* Tab content */
.tab-content { }
.tab-content--hidden { display: none !important; }

/* ── Quantum View (panel derecho) ────────────────────────── */
.qv-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
}

.qv-atom-id { display: flex; align-items: center; gap: 10px; }

.qv-symbol {
    font-family: var(--font-mono);
    font-size: 28px;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    min-width: 32px;
}

.qv-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    display: block;
}

.qv-config {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-dim);
    display: block;
    margin-top: 2px;
}

.btn-close-panel {
    background: rgba(239,83,80,0.12);
    border: 1px solid rgba(239,83,80,0.25);
    color: var(--red);
    border-radius: 6px;
    width: 28px; height: 28px;
    font-size: 13px;
    transition: all 0.18s;
    display: flex; align-items: center; justify-content: center;
}
.btn-close-panel:hover { background: rgba(239,83,80,0.25); }

.qv-canvas-wrap {
    height: 200px;
    background: rgba(0,0,0,0.3);
    border-bottom: 1px solid var(--border);
    position: relative;
    flex-shrink: 0;
    overflow: hidden;
}

.qv-canvas-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--text-xs);
    font-size: 11px;
    line-height: 1.6;
}

.qv-layers,
.qv-material {
    padding: 12px 14px;
    border-bottom: 1px solid var(--border);
}

.qv-layer-list { display: flex; flex-direction: column; gap: 6px; margin-top: 8px; }

.qv-layer-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
}

/* ═══════════════════════════════════════════════════════════
   BOTTOM SHEETS
   ═══════════════════════════════════════════════════════════ */
.bottom-sheet {
    position: fixed;
    bottom: var(--dock-h);
    left: 50%;
    transform: translateX(-50%);
    background: var(--bg-panel);
    backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    border-bottom: none;
    border-radius: var(--radius) var(--radius) 0 0;
    padding: 16px 18px 20px;
    max-width: 92vw;
    max-height: 45vh;
    overflow-y: auto;
    z-index: 140;
    transition: transform 0.28s cubic-bezier(0.4,0,0.2,1),
                opacity 0.28s ease;
}

.bottom-sheet::-webkit-scrollbar { width: 3px; }
.bottom-sheet::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }

.bottom-sheet.hidden {
    transform: translateX(-50%) translateY(110%);
    opacity: 0;
    pointer-events: none;
}

/* Panel agregar: bottom-right */
.bottom-sheet--right {
    left: auto;
    right: 0;
    transform: none;
    border-radius: var(--radius) 0 0 0;
    max-width: 280px;
    max-height: 60vh;
}
.bottom-sheet--right.hidden {
    transform: translateY(110%);
    opacity: 0;
    pointer-events: none;
}

.bs-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 12px;
    text-align: center;
}

/* ═══════════════════════════════════════════════════════════
   DOCK
   ═══════════════════════════════════════════════════════════ */
#dock {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    height: var(--dock-h);
    z-index: 160;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px;
    background: none;
    border-top: none;
    isolation: isolate;
}
#dock::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(6, 8, 16, 0.45);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    z-index: -1;
    transition: opacity 0.5s ease;
}
/* Fade state */
#dock.ui-faded::before {
    opacity: 0;
}
#dock.ui-faded .dock-btn:not(.dock-btn--center) {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
}
/* ▲ center button stays SOLID when faded — needs its own background */
#dock .dock-btn--center {
    transition: opacity 0.4s ease, background 0.4s ease;
}
#dock.ui-faded .dock-btn--center {
    opacity: 1;
    pointer-events: auto;
    background: rgba(6, 8, 16, 0.7);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-color: rgba(255,255,255,0.2);
}

.dock-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    background: none;
    border: none;
    color: var(--text-dim);
    padding: 6px 18px;
    border-radius: var(--radius-sm);
    transition: all 0.18s;
    min-width: 72px;
}

.dock-btn:hover,
.dock-btn.active {
    color: var(--accent);
    background: var(--accent-dim);
}

#dock .dock-btn.dock-btn--center {
    width: 40px; height: 40px;
    min-width: 40px;
    border-radius: 50%;
    padding: 0;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.04);
    flex-shrink: 0;
}

.dock-btn--center:hover,
.dock-btn--center.active {
    border-color: var(--accent);
    background: var(--accent-dim);
    color: var(--accent);
}

.dock-icon { font-size: 16px; line-height: 1; }
.dock-label { font-size: 10px; font-weight: 500; letter-spacing: 0.02em; }

/* Grupos lateral */
.collapse-side {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 155;
    background: var(--bg-panel-alt);
    border: 1px solid var(--border);
    border-right: none;
    border-radius: var(--radius-sm) 0 0 var(--radius-sm);
    color: var(--accent);
    font-size: 11px;
    padding: 10px 8px;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    letter-spacing: 0.05em;
    font-weight: 600;
    transition: all 0.18s;
    backdrop-filter: blur(8px);
}
.collapse-side:hover { background: var(--accent-dim); }

/* ═══════════════════════════════════════════════════════════
   PANEL GROUPS
   ═══════════════════════════════════════════════════════════ */
.group-panel {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    background: var(--bg-panel);
    backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    border-right: none;
    border-radius: var(--radius) 0 0 var(--radius);
    padding: 16px 14px;
    z-index: 145;
    min-width: 210px;
    transition: transform 0.28s ease, opacity 0.28s ease;
}
.group-panel.hidden {
    transform: translateY(-50%) translateX(110%);
    opacity: 0;
    pointer-events: none;
}

/* ═══════════════════════════════════════════════════════════
   ELEMENT SELECTOR
   ═══════════════════════════════════════════════════════════ */
.element-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    max-height: calc(4 * 62px);
    overflow-y: auto;
}

.element-grid::-webkit-scrollbar { width: 3px; }
.element-grid::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }

.element-btn {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 8px 4px;
    border-radius: var(--radius-sm);
    text-align: center;
    transition: all 0.15s;
    min-width: 56px;
}

.element-btn:hover {
    border-color: var(--accent);
    background: var(--accent-dim);
    transform: translateY(-1px);
}

.element-btn.selected {
    border-color: var(--accent);
    background: var(--accent-dim);
    box-shadow: 0 0 8px var(--accent-glow);
}

.element-number { font-size: 9px; color: var(--text-dim); display: block; }
.element-symbol { font-size: 16px; font-weight: 700; display: block; margin: 2px 0; }
.element-name   { font-size: 8px;  color: var(--text-dim); display: block; }

/* ═══════════════════════════════════════════════════════════
   COMPONENTES INTERNOS DE PANELES
   ═══════════════════════════════════════════════════════════ */

/* Sección con separador */
.panel-section {
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
}
.panel-section:last-child { border-bottom: none; }

.panel-section--accent {
    border-color: rgba(255, 213, 79, 0.15);
}

/* Título de sección */
.section-title {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    opacity: 0.7;
    margin-bottom: 8px;
}

/* Checkbox rows */
.check-row {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    cursor: pointer;
    line-height: 1.4;
}

.check-row input[type="checkbox"] {
    margin-top: 2px;
    accent-color: var(--accent);
    flex-shrink: 0;
    width: 14px; height: 14px;
}

/* Hints */
.hint {
    font-size: 10px;
    color: var(--text-xs);
    margin-top: 4px;
    margin-left: 22px;
    line-height: 1.5;
}

/* Slider rows — etiqueta + range + valor */
.slider-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
}

.slider-row span:first-child {
    font-size: 11px;
    color: var(--text-dim);
    white-space: nowrap;
    min-width: 80px;
}

.slider-row input[type="range"] {
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    height: 4px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    outline: none;
    accent-color: var(--accent);
}

.slider-row input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 14px; height: 14px;
    background: var(--accent);
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 0 6px var(--accent-glow);
}

.slider-row input[type="range"]::-moz-range-thumb {
    width: 14px; height: 14px;
    background: var(--accent);
    border-radius: 50%;
    border: none;
    cursor: pointer;
}

.slider-val {
    font-family: var(--font-mono);
    font-size: 10px;
    color: #88ff88;
    min-width: 36px;
    text-align: right;
}

/* Slider wrap (con label arriba) */
.slider-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
}
.slider-wrap input[type="range"] { flex: 1; }

/* Row con botón a la derecha */
.row-with-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
}

/* Botones genéricos */
.btn {
    padding: 8px 14px;
    border-radius: var(--radius-sm);
    font-size: 12px;
    font-weight: 600;
    border: none;
    transition: all 0.18s;
}

.btn--blue {
    background: rgba(79,195,247,0.15);
    color: #4fc3f7;
    border: 1px solid rgba(79,195,247,0.3);
}
.btn--blue:hover { background: rgba(79,195,247,0.28); }

.btn--gold {
    background: rgba(255,213,79,0.15);
    color: var(--gold);
    border: 1px solid rgba(255,213,79,0.3);
}
.btn--gold:hover { background: rgba(255,213,79,0.28); }

.btn--panel {
    background: rgba(255,255,255,0.05);
    color: var(--text);
    border: 1px solid var(--border);
    width: 100%;
    padding: 9px;
}
.btn--panel:hover { background: rgba(255,255,255,0.1); border-color: var(--accent); color: var(--accent); }

.btn-sm {
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 11px;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    color: var(--text-dim);
    transition: all 0.15s;
}
.btn-sm:hover { color: var(--accent); border-color: var(--accent); }

/* Fila de botones */
.btn-row {
    display: flex;
    gap: 8px;
}

/* Segmented control */
.seg-ctrl {
    display: flex;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 3px;
    gap: 2px;
}

.seg-ctrl--3 .seg-btn { flex: 1; }

.seg-btn {
    flex: 1;
    padding: 5px 10px;
    border-radius: 7px;
    border: none;
    background: transparent;
    color: var(--text-dim);
    font-size: 11px;
    font-weight: 500;
    transition: all 0.18s;
}

.seg-btn--active {
    background: var(--accent-dim);
    color: var(--accent);
    font-weight: 700;
}

.mode-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
}

.label-xs {
    font-size: 11px;
    color: var(--text-dim);
    white-space: nowrap;
}

/* Laboratorio warning */
.lab-warning {
    font-size: 11px;
    color: rgba(255,213,79,0.7);
    background: rgba(255,213,79,0.06);
    border-radius: 6px;
    padding: 8px 10px;
    line-height: 1.5;
    margin-bottom: 14px;
}

/* Readout box */
.readout-box {
    background: rgba(0,0,0,0.3);
    border-radius: var(--radius-sm);
    padding: 10px 12px;
    margin: 8px 0;
    border: 1px solid var(--border);
}

.readout-row {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    margin-bottom: 3px;
}
.readout-row:last-child { margin-bottom: 0; }

.readout-val   { color: #ff9933; font-family: var(--font-mono); font-weight: 700; }
.readout-phase { font-family: var(--font-mono); font-weight: 700; }

/* Add panel grids */
.add-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 6px;
}

.add-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
}

/* ═══════════════════════════════════════════════════════════
   TEMPERATURE HUD
   ═══════════════════════════════════════════════════════════ */
.temp-hud {
    position: fixed;
    top: calc(var(--header-h) + 10px);
    right: 12px;
    z-index: 130;
    background: rgba(10,14,30,0.6);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,140,0,0.2);
    border-radius: 10px;
    padding: 8px 12px;
    font-size: 11px;
    pointer-events: none;
    min-width: 150px;
    transition: opacity 0.3s;
}
.temp-hud.hidden { display: none !important; }

.temp-hud__row { display: flex; align-items: center; gap: 6px; padding: 2px 0; }
.temp-hud__label { color: var(--text-dim); min-width: 64px; }
.temp-hud__value { font-family: var(--font-mono); font-size: 12px; color: #ff9933; font-weight: 600; min-width: 52px; text-align: right; }
.temp-hud__phase { font-size: 10px; color: var(--text-dim); }
.temp-hud__divider { height: 1px; background: rgba(255,140,0,0.15); margin: 3px 0; }

/* Loading modal — estilos en css/loader.css */

/* ═══════════════════════════════════════════════════════════
   ERROR OVERLAY
   ═══════════════════════════════════════════════════════════ */
#error-overlay {
    display: none;
    position: fixed;
    bottom: calc(var(--dock-h) + 10px);
    left: 10px; right: 10px;
    max-height: 40vh;
    overflow-y: auto;
    background: rgba(20,0,0,0.85);
    border: 1px solid rgba(255,80,80,0.3);
    border-radius: var(--radius-sm);
    color: #ff6b6b;
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 12px;
    z-index: 9998;
    backdrop-filter: blur(8px);
}

#error-copy-btn {
    display: block;
    margin: 8px 0 0 0;
    padding: 6px 14px;
    background: rgba(255,80,80,0.15);
    border: 1px solid rgba(255,80,80,0.35);
    border-radius: 6px;
    color: #ff9999;
    font-size: 11px;
    cursor: pointer;
}

/* ═══════════════════════════════════════════════════════════
   HINT NOTIFICATION
   ═══════════════════════════════════════════════════════════ */
#hint {
    position: fixed;
    top: calc(var(--header-h) + 10px);
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(8px);
    color: var(--text);
    font-size: 12px;
    padding: 8px 16px;
    border-radius: 20px;
    border: 1px solid var(--border);
    z-index: 300;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
    white-space: nowrap;
}
#hint.visible { opacity: 1; }

/* ═══════════════════════════════════════════════════════════
   UTILIDADES
   ═══════════════════════════════════════════════════════════ */
.hidden { display: none !important; }  /* display:none real */
.vis-hidden { opacity: 0; pointer-events: none; }  /* ocupa espacio */

/* ═══════════════════════════════════════════════════════════
   MOBILE
   ═══════════════════════════════════════════════════════════ */
@media (max-width: 480px) {
    :root { --panel-w: min(272px, 88vw); }

    .hstat b { font-size: 11px; }

    .bottom-sheet--right { max-width: 82vw; }
}

/* ═══════════════════════════════════════════════════════════
   CONSOLA DEL MOTOR
   Panel flotante con log coloreado + input de comandos JS
   ═══════════════════════════════════════════════════════════ */
.dev-console {
    position: fixed;
    bottom: calc(var(--dock-h) + 8px);
    left: 8px;
    width: min(500px, calc(100vw - 16px));
    max-height: 340px;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    background: rgba(4, 6, 12, 0.95);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(79, 195, 247, 0.2);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.28s cubic-bezier(0.4,0,0.2,1), opacity 0.28s ease;
    box-shadow: 0 8px 32px rgba(0,0,0,0.6), 0 0 0 1px rgba(79,195,247,0.05);
}
.dev-console.hidden {
    transform: translateY(110%);
    opacity: 0;
    pointer-events: none;
}

/* En portrait (móvil vertical) la consola va arriba para no taparse con el teclado */
@media (orientation: portrait) {
    .dev-console {
        bottom: auto;
        top: calc(var(--header-h) + 8px);
        width: min(75vw, calc(100vw - 16px));
        max-height: 30vh;
        left: 8px;
    }
    .dev-console.hidden {
        transform: translateY(-110%);  /* sale por arriba */
    }
}

.dev-console__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    background: rgba(10, 14, 24, 0.8);
}

.dev-console__title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
}

.dev-console__actions {
    display: flex;
    align-items: center;
    gap: 6px;
}

/* Botón copiar contenido de la consola */
.dev-console__copy-btn {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.45);
    border-radius: 6px;
    padding: 2px 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    cursor: pointer;
    transition: all 0.15s;
}
.dev-console__copy-btn:hover {
    background: rgba(79,195,247,0.1);
    border-color: rgba(79,195,247,0.3);
    color: var(--accent);
}

/* Log scrollable */
.dev-console__log {
    flex: 1;
    overflow-y: auto;
    padding: 8px 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.7;
    display: flex;
    flex-direction: column;
    gap: 1px;
}

.dev-console__log::-webkit-scrollbar { width: 3px; }
.dev-console__log::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }

/* Entradas del log */
.log-entry {
    display: flex;
    gap: 8px;
    align-items: flex-start;
    padding: 1px 0;
    word-break: break-all;
}

.log-entry__time {
    color: rgba(255,255,255,0.2);
    flex-shrink: 0;
    font-size: 9px;
    margin-top: 2px;
    min-width: 42px;
}

.log-entry__badge {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 1px 5px;
    border-radius: 3px;
    flex-shrink: 0;
    margin-top: 1px;
}

.log-entry__msg { flex: 1; }

/* Tipos de entrada */
.log-entry--info   .log-entry__badge { background: rgba(79,195,247,0.15); color: #4fc3f7; }
.log-entry--info   .log-entry__msg   { color: rgba(216,228,240,0.8); }

.log-entry--warn   .log-entry__badge { background: rgba(255,213,79,0.15); color: #ffd54f; }
.log-entry--warn   .log-entry__msg   { color: #ffd54f; }

.log-entry--error  .log-entry__badge { background: rgba(239,83,80,0.2); color: #ef5350; }
.log-entry--error  .log-entry__msg   { color: #ef5350; }

.log-entry--cmd    .log-entry__badge { background: rgba(105,240,174,0.15); color: #69f0ae; }
.log-entry--cmd    .log-entry__msg   { color: #69f0ae; }

.log-entry--result .log-entry__badge { background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.4); }
.log-entry--result .log-entry__msg   { color: rgba(216,228,240,0.55); }

.log-entry--sys    .log-entry__badge { background: rgba(179,136,255,0.15); color: #b39ddb; }
.log-entry--sys    .log-entry__msg   { color: #b39ddb; }

/* Input row */
.dev-console__input-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
    background: rgba(10, 14, 24, 0.8);
}

.dev-console__prompt {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 14px;
    font-weight: 700;
    flex-shrink: 0;
    opacity: 0.7;
}

.dev-console__input {
    flex: 1;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: #69f0ae;
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 5px 10px;
    outline: none;
    transition: border-color 0.18s;
}
.dev-console__input:focus {
    border-color: rgba(79,195,247,0.4);
    background: rgba(255,255,255,0.07);
}
.dev-console__input::placeholder { color: rgba(255,255,255,0.18); }

/* Botón consola en collapse-side */
.collapse-side--console {
    top: calc(50% + 60px);
    font-size: 15px;
    padding: 10px 6px;
    writing-mode: horizontal-tb;
    border-radius: var(--radius-sm) 0 0 var(--radius-sm);
    letter-spacing: 0;
}

/* Loading config panel — estilos en css/loader.css */

/* ═══════════════════════════════════════════════════════════
   ELEMENT SELECTOR — completar estilos
   ═══════════════════════════════════════════════════════════ */

/* Buscador */
.element-search {
    width: 100%;
    padding: 8px 12px;
    margin-bottom: 10px;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-family: var(--font-ui);
    font-size: 12px;
    outline: none;
    transition: border-color 0.2s;
}
.element-search:focus {
    border-color: var(--accent);
}
.element-search::placeholder { color: var(--text-xs); }



/* Card de elemento — completar lo que falta en .element-btn */
.element-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    cursor: pointer;
}
.element-btn:active { transform: scale(0.95); }

.element-number { font-size: 9px;  color: var(--text-xs);  display: block; line-height: 1; }
.element-symbol { font-size: 15px; font-weight: 700;        display: block; line-height: 1.2; }
.element-name   { font-size: 8px;  color: var(--text-dim);  display: block; line-height: 1;
                  white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%; }

/* ═══════════════════════════════════════════════════════════
   GROUP PANEL — completar estilos
   ═══════════════════════════════════════════════════════════ */

.group-panel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
}

.group-panel__title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-dim);
}

.group-panel__actions {
    display: flex;
    gap: 4px;
}

.group-panel__list {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

/* Item de grupo */
.group-item {
    display: flex;
    align-items: center;
    gap: 9px;
    width: 100%;
    padding: 6px 8px;
    border-radius: var(--radius-sm);
    border: none;
    background: transparent;
    color: var(--text);
    font-family: var(--font-ui);
    font-size: 12px;
    cursor: pointer;
    transition: background 0.15s, opacity 0.2s;
    text-align: left;
}
.group-item:hover { background: rgba(255,255,255,0.05); }

.group-item--off {
    opacity: 0.35;
}

.group-item__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 5px currentColor;
}

.group-item__name {
    flex: 1;
    text-align: left;
}

.group-item__toggle {
    font-size: 9px;
    color: var(--text-xs);
    flex-shrink: 0;
    transition: color 0.15s;
}
.group-item:not(.group-item--off) .group-item__toggle {
    color: var(--accent);
}

/* btn-sm — botón pequeño reutilizable */
.btn-sm {
    padding: 3px 9px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
}
.btn-sm:hover {
    border-color: var(--accent);
    color: var(--accent);
}

/* ── Cursor modo colocación de átomo ─────────────────────────────────────── */
#canvas-wrap.placing,
#canvas-wrap.placing canvas {
    cursor: crosshair;
}

/* ═══════════════════════════════════════════════════════════
   ⚪ RESTORE BUTTON — siempre en esquina superior derecha
   ═══════════════════════════════════════════════════════════ */
#ui-restore-btn {
    position: fixed;
    top: 8px; right: 8px;
    z-index: 250;
    width: 28px; height: 28px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.4);
    font-size: 8px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
}
#ui-restore-btn.visible {
    opacity: 1;
    pointer-events: auto;
}
#ui-restore-btn:hover {
    background: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.7);
    border-color: rgba(255,255,255,0.3);
}

/* ═══════════════════════════════════════════════════════════
   SETTINGS ⚙️ DROPDOWN
   ═══════════════════════════════════════════════════════════ */
.settings-wrap {
    position: relative;
}
.settings-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 170px;
    background: rgba(8, 10, 18, 0.92);
    backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 6px 0;
    z-index: 250;
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
}
.settings-dropdown.open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
}
.settings-dropdown.hidden { display: none; }

.settings-opt {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 8px 14px;
    background: none;
    border: none;
    color: var(--text-dim);
    font-family: var(--font-ui);
    font-size: 12px;
    cursor: pointer;
    transition: all 0.15s;
}
.settings-opt:hover {
    background: var(--accent-dim);
    color: var(--accent);
}
.settings-opt.active {
    color: var(--accent);
}
.settings-opt__icon {
    font-size: 14px;
    width: 20px;
    text-align: center;
}

.settings-slider {
    padding: 6px 14px 8px;
    display: none;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: rgba(255, 200, 0, 0.8);
}
.settings-slider.visible { display: flex; }
.settings-slider input[type="range"] {
    flex: 1;
    accent-color: #ffcc00;
}
.settings-slider span {
    min-width: 30px;
    text-align: right;
}

/* ═══════════════════════════════════════════════════════════
   UTILITY CLASSES — ex inline styles
   ═══════════════════════════════════════════════════════════ */
.mt-xs  { margin-top: 6px; }
.mt-sm  { margin-top: 10px; }
.mt-md  { margin-top: 12px; }
.mt-lg  { margin-top: 16px; }
.mb-md  { margin-bottom: 14px; }
.flex-1 { flex: 1; }
.u-hidden { display: none; }
.text-xs { font-size: 11px; }

/* ── Special buttons ───────────────────────────────────────── */
.btn--compact {
    padding: 6px 10px;
    font-size: 11px;
}
.btn--silverblue {
    width: 100%;
    border-color: rgba(160, 200, 220, 0.4);
    color: #a0c8dc;
    background: rgba(160, 200, 220, 0.08);
}

/* ═══════════════════════════════════════════════════════════
   PORTRAIT MODE — icons only on toggle
   ═══════════════════════════════════════════════════════════ */
@media (max-width: 600px) {
    .mode-toggle__label { display: none; }
    #dock .dock-label { display: none; }
    .dock-btn { min-width: 48px; padding: 6px 10px; }
}

/* ═══════════════════════════════════════════════════════════
   LANDSCAPE — fix joystick/selector overlap
   ═══════════════════════════════════════════════════════════ */
@media (orientation: landscape) and (max-height: 500px) {
    /* Move joystick right to avoid overlap with selection buttons */
    #joystick-zone {
        left: 180px !important;
    }
    /* Compact header/dock for short screens */
    :root {
        --header-h: 42px;
        --dock-h: 44px;
    }
    .dock-btn { min-width: 48px; padding: 4px 10px; }
    #dock .dock-label { display: none; }
}
